# Copy this file to .env and fill in the values before running the pipeline.
# Never commit .env to version control.

# Roboflow API key — obtain from https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# Roboflow workspace and project (used by the download command)
ROBOFLOW_WORKSPACE=recreate
ROBOFLOW_PROJECT=your_project_name_here
ROBOFLOW_VERSION=1
